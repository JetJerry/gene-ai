{
  "extends": "stylelint-config-standard",
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "tailwind",
          "apply",
          "layer",
          "config",
          "theme",
          "custom-variant",
          "import",
          "source"
        ]
      }
    ],
    "function-no-unknown": null,
    "selector-pseudo-element-no-unknown": null
  }
}
